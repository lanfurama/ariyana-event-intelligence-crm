# Synchronized with api/src/config/env.ts (Zod schema is source of truth).
# Required keys are uncommented. Optional keys are prefixed with `# `.

# Server
NODE_ENV=development
PORT=3001

# Database (required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ariyana_crm
DB_USER=your_username
DB_PASSWORD=your_password

# CORS (optional — only the standalone server uses it; vite-plugin-api proxies in dev)
# CORS_ORIGIN=http://localhost:3000

# AI providers (required)
# Gemini — used by backend routes (api/src/routes/gemini.ts, excelImport.ts, leadScoringService.ts)
GEMINI_API_KEY=your_gemini_api_key_here
# OpenAI — used as backup when Gemini has issues (api/src/routes/gpt.ts). GPT-4o mini.
OPENAI_API_KEY=your_openai_api_key_here

# Vertex AI (optional — feature-gated for event enrichment)
# VERTEX_AI_API_KEY=your_vertex_ai_api_key
# VERTEX_AI_PROJECT_ID=your_project_id
# VERTEX_AI_ENDPOINT_ID=your_endpoint_id
# VERTEX_AI_LOCATION=europe-west4
# VERTEX_AI_MODEL=gemini-2.5-pro
# VERTEX_AI_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Outgoing email (SMTP — required)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_marketing_email@furamavietnam.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=marketing@furamavietnam.com

# Incoming email (IMAP — optional; auto-detected from EMAIL_HOST_USER domain if unset)
#   Gmail:        imap.gmail.com
#   Outlook.com:  imap-mail.outlook.com
#   Office 365:   outlook.office365.com
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# Note: Uses same EMAIL_HOST_USER and EMAIL_HOST_PASSWORD as outgoing email

# Optional integrations
# GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# Vercel platform (auto-set in production, leave unset for local dev)
# VERCEL=
# VERCEL_URL=

# Note: Frontend uses /api/v1/* endpoints through vite-plugin-api.
# No VITE_API_URL or VITE_GEMINI_API_KEY needed — everything goes through port 3000.
